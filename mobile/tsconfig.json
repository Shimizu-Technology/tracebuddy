{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./*"],
      "@tracebuddy/shared": ["../shared/index.ts"],
      "@tracebuddy/shared/*": ["../shared/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "../shared/**/*.ts",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
